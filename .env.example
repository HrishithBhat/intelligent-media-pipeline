# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://pipeline:pipeline123@localhost:5432/media_pipeline?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Worker
WORKER_CONCURRENCY=3
JOB_TIMEOUT_MS=120000
JOB_MAX_RETRIES=3

# Analysis thresholds
BLUR_THRESHOLD=100
MIN_BRIGHTNESS=40
MAX_BRIGHTNESS=240
MIN_IMAGE_WIDTH=640
MIN_IMAGE_HEIGHT=480
DUPLICATE_HASH_THRESHOLD=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Logging
LOG_LEVEL=info
