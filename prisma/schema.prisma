generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImageStatus {
  pending
  processing
  completed
  failed
}

enum AttemptStatus {
  started
  completed
  failed
}

model Image {
  id                    String    @id @default(uuid()) @db.Uuid
  originalFilename      String    @map("original_filename")
  mimeType              String    @map("mime_type")
  fileSize              Int       @map("file_size")
  storagePath           String    @map("storage_path")
  status                ImageStatus @default(pending)
  failureReason         String?   @map("failure_reason")
  compositeScore        Float?    @map("composite_score")
  compositeConfidence   Float?    @map("composite_confidence")
  processingStartedAt   DateTime? @map("processing_started_at")
  processingCompletedAt DateTime? @map("processing_completed_at")
  uploadedAt            DateTime  @default(now()) @map("uploaded_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  analysisResults       AnalysisResult[]
  processingAttempts    ProcessingAttempt[]

  @@map("images")
}

model AnalysisResult {
  id         String   @id @default(uuid()) @db.Uuid
  imageId    String   @map("image_id") @db.Uuid
  checkName  String   @map("check_name")
  passed     Boolean
  score      Float
  confidence Float
  details    Json
  createdAt  DateTime @default(now()) @map("created_at")

  image      Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@map("analysis_results")
}

model ProcessingAttempt {
  id             String        @id @default(uuid()) @db.Uuid
  imageId        String        @map("image_id") @db.Uuid
  attemptNumber  Int           @map("attempt_number")
  status         AttemptStatus
  errorMessage   String?       @map("error_message")
  startedAt      DateTime      @default(now()) @map("started_at")
  completedAt    DateTime?     @map("completed_at")

  image          Image         @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@map("processing_attempts")
}
